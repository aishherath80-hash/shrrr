# Backend Environment Configuration

# =============================
# DATABASE CONFIGURATION
# =============================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=shrimp_farm_iot
ENV=prod

# =============================
# API CONFIGURATION
# =============================
HOST=0.0.0.0
PORT=8001
APP_NAME=disease-detection

# =============================
# VIDEO MONITORING CONFIGURATION
# =============================
# IP Camera / Video source
# Examples:
#   - http://192.168.8.128:8080/video (Android IP Webcam)
#   - rtsp://192.168.1.100:554/stream (RTSP Camera)
#   - 0 (Webcam)
#   - test.mp4 (Video file)
VIDEO_SOURCE=http://192.168.8.128:8080/video

# Pond identifier for the video monitoring
POND_ID=pond-01

# Base URL for API
API_BASE_URL=http://127.0.0.1:8001

# =============================
# MODEL CONFIGURATION
# =============================
# Model paths (optional, will use defaults if not set)
MODEL_DIR=models/artifacts
RF_MODEL_PATH=models/artifacts/model_random_forest_multiclass.joblib
IF_MODEL_PATH=models/artifacts/model_isolation_forest.joblib
SCALER_PATH=models/artifacts/multimodal_robust_scaler.joblib
IF_THRESHOLD=-0.003891

# =============================
# MONITORING
# =============================
# Enable MongoDB logging
ENABLE_LOGGING=true
LOG_LEVEL=INFO
